# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=workboard_db
DB_USER=postgres
DB_PASSWORD=Post123G$

# Server port
PORT=3001

# Frontend origin for CORS
FRONTEND_URL=http://localhost:5173

# Backend base URL (used in Microsoft OAuth redirect URI)
BACKEND_URL=http://localhost:3001

# JWT — change to a long random string before deploying to production
JWT_SECRET=ddecor_workboard_jwt_secret_change_in_production_32chars
JWT_EXPIRES_IN=24h

# Session secret (used only for Microsoft OAuth state — short-lived)
SESSION_SECRET=ddecor_session_secret_change_in_production

# ── Microsoft SSO ────────────────────────────────────────────────────────────
# 1. Go to https://portal.azure.com → Azure Active Directory → App registrations
# 2. Click "New registration", set redirect URI to:
#    http://localhost:3001/api/auth/microsoft/callback
# 3. Under "Certificates & secrets" create a client secret
# 4. Fill in the values below:
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:3001/api/auth/microsoft/callback

# ── Inbound Email via M365 / Microsoft Graph API ──────────────────────────────
# Uses the SAME app registration above — just add one extra permission.
#
# ONE-TIME AZURE SETUP (5 minutes):
#   1. portal.azure.com → Azure Active Directory → App registrations → [your app]
#   2. API permissions → Add a permission → Microsoft Graph → Application permissions
#   3. Search "Mail" → tick  Mail.ReadWrite  → Add permissions
#   4. Click "Grant admin consent for [your org]" → Yes
#   5. Set MICROSOFT_TENANT_ID below to your real tenant (NOT "common")
#      Find it: portal.azure.com → Azure Active Directory → Overview → Tenant ID
#   6. Set EMAIL_M365_MAILBOX to the mailbox that will receive the emails
#      (can be a shared mailbox like workboard@ddecor.com or any user mailbox)
#
# NOTE: once EMAIL_M365_MAILBOX is filled, the poller auto-uses Graph API.
#       The Gmail IMAP settings are ignored when M365 is active.
#
EMAIL_M365_MAILBOX=

# ── Email (for password reset links) ─────────────────────────────────────────
# Leave blank — reset links will be printed to the backend console instead
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=D'Decor Workboard <noreply@ddecor.com>

# ── Inbound Email → Create Items (Email Poller) ───────────────────────────────
# How it works:
#   1. Create a dedicated Gmail account  e.g. ddecor.workboard@gmail.com
#   2. Enable 2-Step Verification in Google Account settings
#   3. Go to: myaccount.google.com → Security → App Passwords
#   4. Generate an App Password for "Mail" → paste it as EMAIL_IMAP_PASS
#   5. Set EMAIL_DEFAULT_BOARD_ID + EMAIL_DEFAULT_GROUP_ID to your target board/group
#   6. Restart the backend — it will poll every 2 minutes for new emails
#
# Email format to create an item:
#   To:      ddecor.workboard@gmail.com
#   Subject: New fabric sample request
#            ↑ becomes the item name
#
# Target a specific group via subject prefix:
#   Subject: [In Progress] New fabric sample request
#
# Target a specific board via + subaddress:
#   To: ddecor.workboard+board3@gmail.com         (board 3, default group)
#   To: ddecor.workboard+board3-group7@gmail.com  (board 3, group 7)
#
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_IMAP_USER=ddecor.workboard@gmail.com
EMAIL_IMAP_PASS=jsmmrfljgituaksj
EMAIL_DEFAULT_BOARD_ID=1
EMAIL_DEFAULT_GROUP_ID=1
EMAIL_POLL_INTERVAL_MS=120000
